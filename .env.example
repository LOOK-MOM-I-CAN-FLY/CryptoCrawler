# URL for conneect to PostgreSQL through asyncpg
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=

# URL for connection to Redis
REDIS_URL=

# Секретный ключ для подписания JWT-токенов
# Сгенерируйте случайную строку минимум 32 символа:
# $ openssl rand -hex 32
SECRET_KEY=
